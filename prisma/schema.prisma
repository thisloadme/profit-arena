// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  username     String    @unique
  email        String    @unique
  passwordHash String?
  emailVerified DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  // Financial Summary (denormalized for performance, updated via triggers or jobs)
  netWorth    Decimal @db.Decimal(18, 4) @default(0)
  totalAssets Decimal @db.Decimal(18, 4) @default(0)
  totalDebt   Decimal @db.Decimal(18, 4) @default(0)
  cash        Decimal @db.Decimal(18, 4) @default(0)

  financialStatus     FinancialStatus  @default(STABLE)
  financialStatusManual Boolean         @default(false)

  // Liquidation hook: when netWorth <= 0 for LIQUIDATION_GRACE_DAYS real
  // days in a row, the financial tick liquidates assets, settles loans, and
  // zeroes cash. Set true after fire so it never re-triggers unless reset.
  // liquidateGraceStartedAt: real UTC timestamp when the user first dipped
  // into netWorth <= 0 — null while the user is in healthy territory.
  isLiquidated              Boolean   @default(false)
  liquidateAt               DateTime?  @db.Timestamptz
  liquidateGraceStartedAt   DateTime?  @db.Timestamptz

  // Manual liquidation: settings-page button. Tracked in game-time so the
  // "1 per game-month" cooldown survives real-world clock changes (DST,
  // paused server). Null = never liquidated manually.
  lastManualLiquidateAtTick Int?

  // Bumped on login + logout to invalidate outstanding session JWTs.
  tokenVersion Int @default(0)

  profile          UserProfile?
  accounts         Account[]
  assets           Asset[]
  businesses       Business[]
  employments      Employment[]
  loansGiven       Loan[]            @relation("LoanLender")
  loansTaken       Loan[]            @relation("LoanBorrower")
  transactions     Transaction[]
  notifications    Notification[]
  creditScore      CreditScore?
  tutorialProgress TutorialProgress?
  userAchievements UserAchievement[]
  userQuests       UserQuest[]
  watchedAssets    WatchedAsset[]
  limitOrders      LimitOrder[]

  @@index([netWorth])
  @@map("users")
}

model UserProfile {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @unique @db.Uuid
  avatarUrl   String?
  bio         String?
  dateOfBirth DateTime?
  location    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// OAuth identity linked to a User. One user can have multiple providers.
model Account {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @db.Uuid
  provider          String   // e.g., "google"
  providerAccountId String   // provider's stable user id (Google `sub`)
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

enum FinancialStatus {
  STRUGGLING
  STABLE
  COMFORTABLE
  WEALTHY
}

enum AssetType {
  CASH
  STOCK
  CRYPTO
  BOND
  MUTUAL_FUND
  PROPERTY
}

model Asset {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  type         AssetType
  symbol       String // e.g., "AAPL", "BTC", "GOVT_BOND"
  name         String
  quantity     Decimal @db.Decimal(18, 4)
  averagePrice Decimal @db.Decimal(18, 4)
  currentPrice Decimal @db.Decimal(18, 4) // denormalized, updated periodically
  lastUpdated  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@map("assets")
}

model MarketData {
  id           String    @id @default(uuid()) @db.Uuid
  symbol       String    @unique
  type         AssetType
  currentPrice Decimal @db.Decimal(18, 4)
  volatility   Decimal @db.Decimal(8, 4) // 0.0 - 1.0
  trendFactor  Decimal @db.Decimal(8, 4) // macro influence -1.0 to 1.0
  lastUpdated  DateTime  @updatedAt

  @@map("market_data")
}

model Business {
  id             String   @id @default(uuid()) @db.Uuid
  ownerId        String   @db.Uuid
  name           String
  type           String // Cafe, TechStartup, Retail, etc.
  level          Int      @default(1)
  revenuePerTick Decimal @db.Decimal(18, 4) @default(0)
  expensePerTick Decimal @db.Decimal(18, 4) @default(0)
  employeeCount  Int      @default(1)
  isActive       Boolean  @default(true)
  salaryPerEmployee Decimal @db.Decimal(18, 4) @default(0) // 0 = use type default; player-tunable otherwise
  createdAt      DateTime @default(now())
  createdAtTick  Int      @default(0) // game tick when created
  updatedAt      DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, isActive])
  @@map("businesses")
}

model Employment {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @db.Uuid
  jobId           String?          @db.Uuid
  companyName     String
  position        String
  salaryPerPay    Decimal @db.Decimal(18, 4) @default(0)
  payPeriod       PayPeriod        @default(WEEKLY)
  workStartHour   Int              @default(9)
  workEndHour     Int              @default(17)
  nextPayAtTick   Int              @default(0)
  status          EmploymentStatus @default(ACTIVE)
  noticeUntilTick Int?
  startDate       DateTime         @default(now())
  endDate         DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job?  @relation(fields: [jobId], references: [id])

  @@index([status, nextPayAtTick])
  @@index([userId, status])
  @@map("employments")
}

enum PayPeriod {
  WEEKLY
  MONTHLY
}

enum EmploymentStatus {
  ACTIVE
  NOTICE
  TERMINATED
}

// Job catalog (NPC companies). Multiplayer-safe: static catalog, all players see same jobs.
model Job {
  id            String   @id @default(uuid()) @db.Uuid
  code          String   @unique
  title         String
  company       String
  tier          String // ENTRY | MID | SENIOR
  salaryPerPay  Decimal @db.Decimal(18, 4)
  payPeriod     PayPeriod
  workStartHour Int      @default(9)
  workEndHour   Int      @default(17)
  description   String
  badgeColor    String   @default("primary")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  employments Employment[]

  @@map("jobs")
}

model Loan {
  id              String     @id @default(uuid()) @db.Uuid
  lenderId        String     @db.Uuid
  borrowerId      String?    @db.Uuid
  amount          Decimal @db.Decimal(18, 4)
  interestRate    Decimal @db.Decimal(8, 4) // monthly percentage
  tenorMonths     Int
  remainingAmount Decimal @db.Decimal(18, 4)
  status          LoanStatus @default(PENDING)
  createdAt       DateTime   @default(now())
  dueDate         DateTime?

  lender   User  @relation("LoanLender", fields: [lenderId], references: [id])
  borrower User? @relation("LoanBorrower", fields: [borrowerId], references: [id])

  @@index([lenderId])
  @@index([borrowerId])
  @@map("loans")
}

enum LoanStatus {
  PENDING
  ACTIVE
  PAID
  DEFAULTED
}

model Transaction {
  id           String          @id @default(uuid()) @db.Uuid
  userId       String          @db.Uuid
  type         TransactionType
  amount       Decimal @db.Decimal(18, 4)
  description  String
  relatedAsset String? // symbol if related to asset
  createdAt    DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Perf index — Prisma can't represent DESC ordering. Actual index
  // transactions_userId_createdAt_idx (with createdAt DESC) is created by
  // migration 20260717000002.
  @@map("transactions")
}

enum TransactionType {
  BUY
  SELL
  SALARY
  BUSINESS_REVENUE
  EXPENSE
  LOAN_GIVEN
  LOAN_RECEIVED
  LOAN_PAYMENT
  LOAN_INTEREST
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Perf index — Prisma can't represent DESC ordering, so the actual index
  // is created by migration 20260717000002 (notifications_userId_isRead_createdAt_idx
  // with createdAt DESC). Kept manual to avoid recreating without DESC.
  @@map("notifications")
}

model GameEvent {
  id           String    @id @default(uuid()) @db.Uuid
  eventType    String
  description  String
  impactFactor Decimal @db.Decimal(8, 4) // global impact
  startAt      DateTime
  endAt        DateTime?
  isActive     Boolean   @default(true)

  @@map("game_events")
}

// Historical price snapshot per asset, used for charts.
model PriceHistory {
  id     String   @id @default(uuid()) @db.Uuid
  symbol String
  price  Decimal @db.Decimal(18, 4)
  tickAt DateTime @default(now())

  @@index([symbol, tickAt])
  @@map("price_history")
}

// 1-1 with User. Simple credit score (300-850).
model CreditScore {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid
  score     Int      @default(700)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_scores")
}

// Tutorial step progress (1-1 with User).
model TutorialProgress {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @db.Uuid
  currentStep       Int      @default(0)
  completed         Boolean  @default(false)
  skipped           Boolean  @default(false)
  dismissedTooltips String[] @default([])
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tutorial_progress")
}

// Cached leaderboard row.
model LeaderboardSnapshot {
  id         String            @id @default(uuid()) @db.Uuid
  userId     String            @db.Uuid
  period     LeaderboardPeriod
  rank       Int
  netWorth   Decimal @db.Decimal(18, 4)
  prevRank   Int?
  snapshotAt DateTime          @default(now())

  @@unique([period, userId])
  @@index([period, rank])
  @@map("leaderboard_snapshots")
}

enum LeaderboardPeriod {
  ALL_TIME
  WEEKLY
}

model Achievement {
  id          String @id @default(uuid()) @db.Uuid
  code        String @unique // e.g., FIRST_MILLION
  name        String
  description String
  iconKey     String @default("badge")

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  achievementId String   @db.Uuid
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model Quest {
  id          String @id @default(uuid()) @db.Uuid
  code        String @unique
  title       String
  description String
  targetCount Int    @default(1)
  rewardCash  Decimal @db.Decimal(18, 4) @default(0)

  userQuests UserQuest[]

  @@map("quests")
}

model UserQuest {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  questId    String   @db.Uuid
  periodDate DateTime // the day this quest belongs to (date only)
  progress   Int      @default(0)
  completed  Boolean  @default(false)
  claimed    Boolean  @default(false)
  createdAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest Quest @relation(fields: [questId], references: [id])

  @@unique([userId, questId, periodDate])
  @@index([userId, periodDate])
  @@map("user_quests")
}

model WatchedAsset {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  symbol String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@map("watched_assets")
}

enum OrderType {
  BUY
  SELL
}

enum OrderStatus {
  PENDING
  EXECUTED
  CANCELLED
}

model LimitOrder {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String      @db.Uuid
  symbol     String
  type       OrderType
  quantity   Decimal @db.Decimal(18, 4)
  limitPrice Decimal? @db.Decimal(18, 4)
  status     OrderStatus @default(PENDING)
  createdAt  DateTime    @default(now())
  executedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, symbol])
  @@map("limit_orders")
}

model SimulationState {
  id         Int      @id @default(1)
  tickNumber Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@map("simulation_state")
}
